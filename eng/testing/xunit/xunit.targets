<Project>
  <PropertyGroup Condition="'$(TargetFrameworkIdentifier)' == '.NETFramework'">
    <AutoGenerateBindingRedirects Condition="'$(AutoGenerateBindingRedirects)' == ''">true</AutoGenerateBindingRedirects>
    <GenerateBindingRedirectsOutputType Condition="'$(GenerateBindingRedirectsOutputType)' == ''">true</GenerateBindingRedirectsOutputType>
  </PropertyGroup>

  <!-- Run target (F5) support. -->
  <PropertyGroup>
    <RunWorkingDirectory Condition="'$(RunWorkingDirectory)' == ''">$(OutDir)</RunWorkingDirectory>
  </PropertyGroup>

  <PropertyGroup Condition="'$(TargetFrameworkIdentifier)' == '.NETCoreApp' and '$(RunCommand)' == ''">
    <RunCommand>$(DotNetTool)</RunCommand>
    <RunArguments>test $(TargetPath) --settings $(OutDir).runsettings</RunArguments>
  </PropertyGroup>

  <PropertyGroup Condition="'$(TargetFrameworkIdentifier)' == '.NETFramework'">
    <RunCommand>$(DevEnvDir)Extensions\TestPlatform\vstest.console.exe</RunCommand>
    <RunArguments>$(TargetPath) --settings:$(OutDir).runsettings</RunArguments>
  </PropertyGroup>

  <!--
    The xunit.v3.core.mtp-v1 package's buildTransitive props unconditionally
    set UseAppHost=true.  Override UseAppHost=false here (in targets, imported
    after NuGet package props) so our value wins.  Library tests run via
    dotnet exec or Helix.  Mobile/WASM tests use OutputType=Library.
    NativeAOT generates native executables directly via ILC.  None of these
    need an apphost.

    For non-NativeAOT SingleFile tests, tests.singlefile.targets already
    sets UseAppHost=true and SelfContained=true, which is correct.  The
    TestSingleFile condition preserves that, and the NativeAOT condition
    overrides it back to false.

    The SDK exempts mobile/WASM/NativeAOT RIDs from the NETSDK1067 error
    (SelfContained + UseAppHost=false) via _RuntimeIdentifierUsesAppHost.
    For NativeAOT during build (_IsPublishing is false), we must also set
    _RuntimeIdentifierUsesAppHost=false to prevent NETSDK1067.
  -->
  <PropertyGroup Condition="'$(TestSingleFile)' != 'true'">
    <UseAppHost>false</UseAppHost>
  </PropertyGroup>
  <PropertyGroup Condition="'$(TestNativeAot)' == 'true'">
    <UseAppHost>false</UseAppHost>
    <_RuntimeIdentifierUsesAppHost>false</_RuntimeIdentifierUsesAppHost>
  </PropertyGroup>

  <!--
    The xunit.v3.core.mtp-v1 package injects DefaultRunnerReporters.cs into
    compilation. On mobile/WASM, the compilation environment may lack the
    netstandard reference that xunit.v3.runner.common.dll depends on, causing
    CS0012. Since mobile/WASM tests use custom test runners and don't need the
    built-in runner reporters, disable them.
  -->
  <PropertyGroup Condition="'$(TargetsMobile)' == 'true'">
    <XunitRegisterBuiltInRunnerReporters>false</XunitRegisterBuiltInRunnerReporters>
  </PropertyGroup>

  <!--
    Override the xunit.v3.core.mtp-v1 validation target. The original target
    errors when OutputType != Exe or UseAppHost != true on .NETCoreApp. In
    dotnet/runtime, mobile and browser-wasm platforms legitimately use
    OutputType=Library (they have custom test runners), and library tests use
    UseAppHost=false (they are executed via dotnet exec or archived for Helix).
    This target replaces the NuGet package's original.
  -->
  <Target Name="_XunitValidateBuild" BeforeTargets="BeforeBuild" Condition=" '$(TargetFramework)' != '' ">
    <Error Text="xUnit.net v3 test projects must be executable (set project property '&lt;OutputType&gt;Exe&lt;/OutputType&gt;'). If this is not a test project, reference xunit.v3.extensibility.core instead."
           Condition=" '$(OutputType)' != 'Exe' AND '$(TargetsMobile)' != 'true' " />
  </Target>

  <Import Project="$(MSBuildThisFileDirectory)xunit.console.targets" />
</Project>
