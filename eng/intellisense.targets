<Project>

  <PropertyGroup>
    <UseCompilerGeneratedDocXmlFile Condition="'$(UseCompilerGeneratedDocXmlFile)' == ''">true</UseCompilerGeneratedDocXmlFile>
    <!-- Set IsPlatformNotSupportedAssembly when GeneratePlatformNotSupportedAssemblyMessage is set so it can flow through
         AdditionalTargetFrameworkInfoProperty to the outer build for doc XML discovery. -->
    <IsPlatformNotSupportedAssembly Condition="'$(IsPlatformNotSupportedAssembly)' == '' and '$(GeneratePlatformNotSupportedAssemblyMessage)' != ''">true</IsPlatformNotSupportedAssembly>
    <!-- IsCandidateCompilerGeneratedDocFile is set to $(TargetFramework) for inner builds that can serve as the doc
         source for PNSE sibling builds: the TF must be compatible with NetCoreAppCurrent and not itself be PNSE.
         Storing the TF name as the value (instead of 'true') lets the outer build extract it from
         AdditionalPropertiesFromProject via a regex without extra per-TF MSBuild calls. -->
    <IsCandidateCompilerGeneratedDocFile
      Condition="'$(TargetFramework)' != '' and
                 '$(GeneratePlatformNotSupportedAssemblyMessage)' == '' and
                 $([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', '$(NetCoreAppCurrent)'))">$(TargetFramework)</IsCandidateCompilerGeneratedDocFile>
  </PropertyGroup>

  <PropertyGroup Condition="'$(UseCompilerGeneratedDocXmlFile)' != 'true'">
    <IntellisensePackageXmlRootFolder>$([MSBuild]::NormalizeDirectory('$(NuGetPackageRoot)', 'microsoft.private.intellisense', '$(MicrosoftPrivateIntellisenseVersion)', 'IntellisenseFiles'))</IntellisensePackageXmlRootFolder>
    <!-- Replace net10.0 with 'net-$(NetCoreAppCurrentVersion)' once we have a intellisense package with updated docs -->
    <IntellisensePackageXmlFilePathFromNetVersionFolder>$([MSBuild]::NormalizePath('$(IntellisensePackageXmlRootFolder)', 'net-10.0', '1033', '$(AssemblyName).xml'))</IntellisensePackageXmlFilePathFromNetVersionFolder>
    <IntellisensePackageXmlFilePathFromNetFolder>$([MSBuild]::NormalizePath('$(IntellisensePackageXmlRootFolder)', 'net', '1033', '$(AssemblyName).xml'))</IntellisensePackageXmlFilePathFromNetFolder>
    <IntellisensePackageXmlFilePath Condition="'$(IntellisensePackageXmlFilePath)' == '' and Exists($(IntellisensePackageXmlFilePathFromNetVersionFolder))">$(IntellisensePackageXmlFilePathFromNetVersionFolder)</IntellisensePackageXmlFilePath>
    <IntellisensePackageXmlFilePath Condition="'$(IntellisensePackageXmlFilePath)' == '' and Exists($(IntellisensePackageXmlFilePathFromNetFolder))">$(IntellisensePackageXmlFilePathFromNetFolder)</IntellisensePackageXmlFilePath>

    <IntermediateDocFileItemFromIntellisensePackage>$([MSBuild]::NormalizePath('$(IntermediateOutputPath)', 'intellisense-package', '$(TargetName).xml'))</IntermediateDocFileItemFromIntellisensePackage>

    <!-- Suppress "CS1591 - Missing XML comment for publicly visible type or member" compiler errors when the intellisense package xml file is used. -->
    <NoWarn Condition="'$(SkipIntellisenseNoWarnCS1591)' != 'true'">$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <!-- Flow these properties to consuming projects for Microsoft.Internal.Runtime.DotNetApiDocs.Transport.proj to only
       include the source of truth compiler generated documentation files. -->
  <ItemDefinitionGroup>
    <TargetPathWithTargetPlatformMoniker>
      <UseCompilerGeneratedDocXmlFile>$(UseCompilerGeneratedDocXmlFile)</UseCompilerGeneratedDocXmlFile>
      <IsPartialFacadeAssembly>$(IsPartialFacadeAssembly)</IsPartialFacadeAssembly>
      <IsPlatformNotSupportedAssembly>$(IsPlatformNotSupportedAssembly)</IsPlatformNotSupportedAssembly>
      <SuppressPlatformNotSupportedAssemblyDocXmlError>$(SuppressPlatformNotSupportedAssemblyDocXmlError)</SuppressPlatformNotSupportedAssemblyDocXmlError>
    </TargetPathWithTargetPlatformMoniker>
  </ItemDefinitionGroup>

  <ItemGroup>
    <PackageDownload Include="Microsoft.Private.Intellisense" Version="[$(MicrosoftPrivateIntellisenseVersion)]" />
    <!-- Flow IsPlatformNotSupportedAssembly and IsCandidateCompilerGeneratedDocFile to the outer build via
         AdditionalTargetFrameworkInfoProperty so that GetTargetFrameworks can identify which TF to use as the
         doc source for PNSE builds. IsCandidateCompilerGeneratedDocFile is set to the TF name so the outer
         build can extract it from AdditionalPropertiesFromProject via a simple regex. -->
    <AdditionalTargetFrameworkInfoProperty Include="IsPlatformNotSupportedAssembly" />
    <AdditionalTargetFrameworkInfoProperty Include="IsCandidateCompilerGeneratedDocFile" />
  </ItemGroup>

  <!-- Warn if the docs team provided package doesn't have an intellisense file for a given library and the library explicitly
       opts out from using the compiler generated xml file. For PNSE builds the doc XML comes from a non-PNSE sibling
       target framework, so the warning is not applicable. -->
  <Target Name="ValidateIntellisensePackageXmlFilePathExists"
          Condition="'$(UseCompilerGeneratedDocXmlFile)' != 'true' and
                     '$(IntellisensePackageXmlFilePath)' == '' and
                     '$(IsPlatformNotSupportedAssembly)' != 'true'"
          BeforeTargets="CoreCompile">
    <Warning Text="The 'UseCompilerGeneratedDocXmlFile' property was set to '$(UseCompilerGeneratedDocXmlFile)', but the doc team doesn't provide a file for this assembly. Remove the 'UseCompilerGeneratedDocXmlFile' property to let the compiler generate the file." />
  </Target>

  <!-- Prepare the intellisense package xml file by copying it to the project's intermediate folder and update its file timestamp.
       This is necessary so that all project outputs are newer than all project inputs. Directly copying from the intellisense package
       would violate that and break fast up-to-date check. -->
  <Target Name="PrepareIntellisensePackageXmlFile"
          Inputs="$(IntellisensePackageXmlFilePath)"
          Outputs="$(IntermediateDocFileItemFromIntellisensePackage)">
    <Copy SourceFiles="$(IntellisensePackageXmlFilePath)"
          DestinationFiles="$(IntermediateDocFileItemFromIntellisensePackage)" />

    <Touch Files="$(IntermediateDocFileItemFromIntellisensePackage)" />
  </Target>

  <!-- Replace the compiler generated xml file in the obj folder with the one that comes from the intellisense package.
       For PNSE assemblies, GetDocFileFromNonPNSEBuild handles the doc file instead. -->
  <Target Name="ChangeDocumentationFileForPackaging"
          DependsOnTargets="PrepareIntellisensePackageXmlFile"
          BeforeTargets="CopyFilesToOutputDirectory;DocumentationProjectOutputGroup"
          Condition="'$(UseCompilerGeneratedDocXmlFile)' != 'true' and '$(IntellisensePackageXmlFilePath)' != '' and '$(IsPlatformNotSupportedAssembly)' != 'true'">
    <ItemGroup>
      <DocFileItem Remove="@(DocFileItem)" />
      <DocFileItem Include="$(IntermediateDocFileItemFromIntellisensePackage)" />
    </ItemGroup>
  </Target>

  <!-- Allow P2Ps to retrieve the DocFileItem path. -->
  <Target Name="AnnotateTargetPathWithTargetPlatformMonikerWithDocFileItem"
          DependsOnTargets="ChangeDocumentationFileForPackaging;GetDocFileFromNonPNSEBuild;GetTargetPathWithTargetPlatformMoniker"
          BeforeTargets="GetTargetPath">
    <ItemGroup>
      <TargetPathWithTargetPlatformMoniker DocFileItem="@(DocFileItem)" />
    </ItemGroup>
  </Target>

  <!-- Returns the DocFileItem for this build after preparing it (e.g. copying from the intellisense package). -->
  <Target Name="GetDocFileItemPath"
          DependsOnTargets="ChangeDocumentationFileForPackaging"
          Returns="@(DocFileItem)">
  </Target>

  <!-- For PNSE builds that opt out of compiler-generated doc XML, calls GetTargetFrameworks on the outer build to
       identify the first compatible non-PNSE sibling target framework via IsCandidateCompilerGeneratedDocFile in
       AdditionalPropertiesFromProject, then adds a ProjectReference to that sibling.  The ProjectReference ensures
       the sibling is built (and its doc file prepared) before GetDocFileFromNonPNSEBuild retrieves it. -->
  <Target Name="AddPNSEDocSourceProjectReference"
          BeforeTargets="ResolveProjectReferences"
          Condition="'$(IsPlatformNotSupportedAssembly)' == 'true' and
                     '$(UseCompilerGeneratedDocXmlFile)' != 'true' and
                     '$(IsCrossTargetingBuild)' != 'true'">

    <!-- GetTargetFrameworks is the standard outer-build target that aggregates per-TF metadata collected via
         AdditionalTargetFrameworkInfoProperty, including IsCandidateCompilerGeneratedDocFile. -->
    <MSBuild Projects="$(MSBuildProjectFullPath)"
             Targets="GetTargetFrameworks"
             RemoveProperties="TargetFramework">
      <Output ItemName="_PNSEDocTFResult" TaskParameter="TargetOutputs" />
    </MSBuild>

    <PropertyGroup>
      <_PNSEDocAdditionalProps>@(_PNSEDocTFResult->'%(AdditionalPropertiesFromProject)')</_PNSEDocAdditionalProps>
      <!-- IsCandidateCompilerGeneratedDocFile is stored as the TF name for qualifying TFs, so a simple regex
           finds the first non-empty value, which is the candidate TF name. -->
      <_PNSEDocSourceTF>$([System.Text.RegularExpressions.Regex]::Match('$(_PNSEDocAdditionalProps)', 'IsCandidateCompilerGeneratedDocFile="([^"]+)"').Groups[1].Value)</_PNSEDocSourceTF>
    </PropertyGroup>

    <Error Condition="'$(_PNSEDocSourceTF)' == '' and '$(SuppressPlatformNotSupportedAssemblyDocXmlError)' != 'true'"
           Text="$(MSBuildProjectName): Could not find a compatible non-PNSE target framework to use as the documentation source for PNSE builds. Set 'SuppressPlatformNotSupportedAssemblyDocXmlError=true' to suppress this error." />

    <!-- A private ProjectReference to the same project with the candidate TF ensures the sibling is fully built
         (including its doc file) before GetDocFileFromNonPNSEBuild copies it. -->
    <ItemGroup Condition="'$(_PNSEDocSourceTF)' != ''">
      <ProjectReference Include="$(MSBuildProjectFullPath)">
        <SetTargetFramework>TargetFramework=$(_PNSEDocSourceTF)</SetTargetFramework>
        <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
        <Private>false</Private>
      </ProjectReference>
    </ItemGroup>
  </Target>

  <!-- For PNSE builds that opt out of compiler-generated doc XML, retrieves the doc file from the non-PNSE sibling
       TF (identified by AddPNSEDocSourceProjectReference) and uses it as this build's doc file.  The sibling is
       already built via the ProjectReference added by AddPNSEDocSourceProjectReference. -->
  <Target Name="GetDocFileFromNonPNSEBuild"
          DependsOnTargets="AddPNSEDocSourceProjectReference"
          Condition="'$(IsPlatformNotSupportedAssembly)' == 'true' and
                     '$(UseCompilerGeneratedDocXmlFile)' != 'true' and
                     '$(IsCrossTargetingBuild)' != 'true'"
          BeforeTargets="CopyFilesToOutputDirectory;DocumentationProjectOutputGroup">

    <!-- GetDocFileItemPath on the sibling is a fast no-rebuild call because the sibling was already built via the
         ProjectReference added by AddPNSEDocSourceProjectReference. -->
    <MSBuild Projects="$(MSBuildProjectFullPath)"
             Targets="GetDocFileItemPath"
             Properties="TargetFramework=$(_PNSEDocSourceTF)"
             Condition="'$(_PNSEDocSourceTF)' != ''">
      <Output ItemName="_DocFileItemFromSibling" TaskParameter="TargetOutputs" />
    </MSBuild>

    <!-- Copy the sibling's doc file into this build's intermediate output directory so all outputs are
         newer than all inputs (consistent with how PrepareIntellisensePackageXmlFile works). -->
    <Copy SourceFiles="@(_DocFileItemFromSibling)"
          DestinationFiles="$(IntermediateDocFileItemFromIntellisensePackage)"
          Condition="'@(_DocFileItemFromSibling)' != ''" />

    <Touch Files="$(IntermediateDocFileItemFromIntellisensePackage)"
           Condition="'@(_DocFileItemFromSibling)' != ''" />

    <!-- Replace the DocFileItem with the copy we made from the sibling target framework. -->
    <ItemGroup Condition="'@(_DocFileItemFromSibling)' != ''">
      <DocFileItem Remove="@(DocFileItem)" />
      <DocFileItem Include="$(IntermediateDocFileItemFromIntellisensePackage)" />
    </ItemGroup>
  </Target>

</Project>
