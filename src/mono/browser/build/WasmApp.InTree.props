<Project>
  <!-- This depends on the root Directory.Build.props imported this file -->
  <PropertyGroup>
    <UsingMicrosoftNETSdkWebAssembly>true</UsingMicrosoftNETSdkWebAssembly>

    <WasmCommonTargetsPath Condition="Exists('$(MSBuildThisFileDirectory)WasmApp.Common.props')">$(MSBuildThisFileDirectory)</WasmCommonTargetsPath>
    <WasmCommonTargetsPath Condition="'$(WasmCommonTargetsPath)' == ''">$([MSBuild]::NormalizeDirectory($(MonoProjectRoot), 'wasm', 'build'))</WasmCommonTargetsPath>

    <_WebAssemblyPropsFile Condition="'$(_WebAssemblyPropsFile)' == ''">$(MonoProjectRoot)\nuget\Microsoft.NET.Sdk.WebAssembly.Pack\build\Microsoft.NET.Sdk.WebAssembly.Browser.props</_WebAssemblyPropsFile>
    <_WebAssemblyTargetsFile Condition="'$(_WebAssemblyTargetsFile)' == ''">$(MonoProjectRoot)\nuget\Microsoft.NET.Sdk.WebAssembly.Pack\build\Microsoft.NET.Sdk.WebAssembly.Browser.targets</_WebAssemblyTargetsFile>
    <_WebAssemblySdkToolsDirectory Condition="'$(_WebAssemblySdkToolsDirectory)' == ''">$(ArtifactsBinDir)\Microsoft.NET.Sdk.WebAssembly.Pack.Tasks\$(RuntimeConfiguration)\</_WebAssemblySdkToolsDirectory>
  </PropertyGroup>

  <Import Sdk="Microsoft.NET.Sdk.WebAssembly" Project="Sdk.props" Condition="'$(UsingNativeAOT)' != 'true' and '$(UsingMicrosoftNETSdkWebAssembly)' == 'true'" />
  <Import Project="$(MSBuildThisFileDirectory)BrowserWasmApp.props" Condition="'$(UsingNativeAOT)' != 'true' and '$(RuntimeFlavor)' == 'Mono'" />

  <PropertyGroup Condition="'$(RuntimeFlavor)' == 'CoreCLR'">
    <UseMonoRuntime>false</UseMonoRuntime>
    <!-- TODO-WASM https://github.com/dotnet/runtime/issues/120226 (CoreCLR on wasm defaults) -->
    <InvariantGlobalization Condition="'$(InvariantGlobalization)' == ''">false</InvariantGlobalization>
  </PropertyGroup>

  <!-- ReadyToRun (R2R) for WebAssembly: tool/reference paths consumed by the SDK's
       _WasmCrossgenReadyToRunForBuild/_WasmCrossgenReadyToRunForPublish targets when a project opts in
       via @(WasmReadyToRunAssembly). These point at the in-tree build outputs and are the in-repo
       override only: when set, the SDK's _WasmResolveReadyToRunCompiler target leaves them as-is; when
       unset (shipping SDK), it resolves crossgen2 and the wasm JIT from the restored
       Microsoft.NETCore.App.Crossgen2.<hostRID> pack instead. -->
  <PropertyGroup Condition="'$(RuntimeFlavor)' == 'CoreCLR' and '$(TargetOS)' == 'browser'">
    <!-- Architecture of the host crossgen2 tool (not the wasm target). -->
    <_WasmCrossgen2HostArch Condition="'$(_WasmCrossgen2HostArch)' == ''">x64</_WasmCrossgen2HostArch>
    <_WasmCrossgen2ToolsDir>$(ArtifactsBinDir)coreclr\browser.wasm.$(Configuration)\$(_WasmCrossgen2HostArch)\</_WasmCrossgen2ToolsDir>
    <_WasmCrossgen2Path Condition="'$(_WasmCrossgen2Path)' == '' and '$(OS)' == 'Windows_NT'">$(_WasmCrossgen2ToolsDir)crossgen2\crossgen2.exe</_WasmCrossgen2Path>
    <_WasmCrossgen2Path Condition="'$(_WasmCrossgen2Path)' == ''">$(_WasmCrossgen2ToolsDir)crossgen2\crossgen2</_WasmCrossgen2Path>
    <!-- Host wasm JIT used by crossgen2 (- -jitpath). Native library name is OS-specific. -->
    <_WasmCrossgen2JitName Condition="'$(_WasmCrossgen2JitName)' == '' and '$(OS)' == 'Windows_NT'">clrjit_universal_wasm_$(_WasmCrossgen2HostArch).dll</_WasmCrossgen2JitName>
    <_WasmCrossgen2JitName Condition="'$(_WasmCrossgen2JitName)' == '' and $([MSBuild]::IsOSPlatform('OSX'))">libclrjit_universal_wasm_$(_WasmCrossgen2HostArch).dylib</_WasmCrossgen2JitName>
    <_WasmCrossgen2JitName Condition="'$(_WasmCrossgen2JitName)' == ''">libclrjit_universal_wasm_$(_WasmCrossgen2HostArch).so</_WasmCrossgen2JitName>
    <_WasmCrossgen2JitPath Condition="'$(_WasmCrossgen2JitPath)' == ''">$(_WasmCrossgen2ToolsDir)$(_WasmCrossgen2JitName)</_WasmCrossgen2JitPath>
    <_WasmReadyToRunReferenceAssembliesPath Condition="'$(_WasmReadyToRunReferenceAssembliesPath)' == ''">$(ArtifactsBinDir)microsoft.netcore.app.runtime.browser-wasm\$(Configuration)\runtimes\browser-wasm\</_WasmReadyToRunReferenceAssembliesPath>
    <!-- -O works around the MinOpts wasm R2R JIT assert (https://github.com/dotnet/runtime/issues/129630).
         JitWasmNyiToR2RUnsupported lets NYI methods fall back at runtime instead of failing crossgen.
         JitWasmSimdNyiToR2RUnsupported does the same for the NYI_WASM_SIMD paths (parity with
         crossgen-corelib.proj), otherwise SIMD methods crash crossgen2
         (https://github.com/dotnet/runtime/issues/129745). -->
    <_WasmCrossgen2ExtraArgs Condition="'$(_WasmCrossgen2ExtraArgs)' == ''">--codegenopt:JitWasmNyiToR2RUnsupported=1 --codegenopt:JitWasmSimdNyiToR2RUnsupported=1 -O</_WasmCrossgen2ExtraArgs>
  </PropertyGroup>

  <PropertyGroup Condition="'$(RuntimeFlavor)' == 'Mono'">
    <UseMonoRuntime>true</UseMonoRuntime>
  </PropertyGroup>

  <PropertyGroup Condition="'$(IsTestProject)' == 'true' or '$(IsOutputTypeLibrary)' == 'true'">
    <OutputType>library</OutputType>
  </PropertyGroup>
  <PropertyGroup>
    <UsingBlazorAOTWorkloadManifest Condition="'$(UsingBrowserRuntimeWorkload)' == 'true'">true</UsingBlazorAOTWorkloadManifest>
  </PropertyGroup>

  <!-- Don't set defaults for test, because the test projects themselves can set the target* properties -->
  <PropertyGroup Condition="'$(_WasmInTreeDefaults)' != 'false'">
    <SelfContained>true</SelfContained>
    <Platform>AnyCPU</Platform>
    <EnableTargetingPackDownload>false</EnableTargetingPackDownload>
    <TargetFramework>$(NetCoreAppCurrent)</TargetFramework>
    <EMSDK_PATH Condition="'$(EMSDK_PATH)' == '' and '$(MonoProjectRoot)' != ''">$([MSBuild]::NormalizeDirectory($(MonoProjectRoot), 'browser', 'emsdk'))</EMSDK_PATH>
    <RunAOTCompilation Condition="'$(RunAOTCompilation)' == ''">false</RunAOTCompilation>
    <PublishTrimmed>true</PublishTrimmed>
    <RunAnalyzers>false</RunAnalyzers>

    <DisableImplicitFrameworkReferences>false</DisableImplicitFrameworkReferences>
    <UseLocalTargetingRuntimePack Condition="'$(UseLocalTargetingRuntimePack)' == ''">true</UseLocalTargetingRuntimePack>
    <!-- Tests don't yet use a live build of the apphost: https://github.com/dotnet/runtime/issues/58109. -->
    <UseLocalAppHostPack Condition="'$(UseLocalAppHostPack)' == ''">false</UseLocalAppHostPack>
    <EnableTargetingPackDownload>false</EnableTargetingPackDownload>
    <GenerateErrorForMissingTargetingPacks>false</GenerateErrorForMissingTargetingPacks>
    <ImportTargetingPacksTargetsInWasmAppTargets>true</ImportTargetingPacksTargetsInWasmAppTargets>
  </PropertyGroup>

  <!-- This is temporary hack for https://github.com/dotnet/runtime/issues/61294 -->
  <ItemGroup>
    <_MonoRuntimeComponentDontLink Include="libmono-component-debugger-stub-static.a" />
    <_MonoRuntimeComponentDontLink Include="libmono-component-hot_reload-stub-static.a" />
    <_MonoRuntimeComponentDontLink Include="libmono-component-marshal-ilgen-stub-static.a" />
  </ItemGroup>
</Project>
