<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Library</OutputType>
    <AssemblyName>EquatableAssets</AssemblyName>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
    <SkipTestRun>true</SkipTestRun>
    <TargetFramework>$(NetCoreAppToolCurrent)</TargetFramework>
    <!-- Don't add references to the netstandard platform since this is a core assembly -->
    <DisableImplicitFrameworkReferences>true</DisableImplicitFrameworkReferences>
    <RunAnalyzers>false</RunAnalyzers>
    <!-- The field-wise Equals scan recognizes the IL shape emitted by an optimized (Release) build,
         matching the CoreCLR VM. Force optimization so the test is independent of the build config. -->
    <Optimize>true</Optimize>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\nativeaot\Test.CoreLib\src\Test.CoreLib.csproj" />
  </ItemGroup>

</Project>
