<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>$(NetCoreAppToolCurrent)</TargetFramework>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Platforms>x64;x86</Platforms>
    <!-- Suppress analyzer warnings in old prototype code -->
    <NoWarn>$(NoWarn);SA1400;SA1121;IDE0074;IDE0059;CA1859;SA1028;SA1205;CA1805;IDE0036;SA1000;SA1206;IDE0200;IDE0054;IDE0060;CA1822;SA1129;CA1852;IDE0005;CS8600;CS8601;CS8602;CS8603;CS8604;CS8618;CS8625;CS8765;CS8769;CA2208;CS0436;CA1866;CS8620</NoWarn>
    <Nullable>annotations</Nullable>
    <ToolsCommonPath>$(MSBuildThisFileDirectory)..\Common\</ToolsCommonPath>
    <TypeSystemPath>$(ToolsCommonPath)TypeSystem\</TypeSystemPath>
    <DefineConstants>$(DefineConstants);ILTRIM</DefineConstants>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="System.Reflection.Metadata" Version="$(SystemReflectionMetadataVersion)" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../aot/ILCompiler.DependencyAnalysisFramework/ILCompiler.DependencyAnalysisFramework.csproj" />
