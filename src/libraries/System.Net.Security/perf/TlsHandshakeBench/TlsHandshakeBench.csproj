<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>$(NetCoreAppCurrent)</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <ServerGarbageCollection>true</ServerGarbageCollection>
    <!-- BenchmarkDotNet feed -->
    <RestoreSources>https://api.nuget.org/v3/index.json</RestoreSources>
    <!-- Not part of the libraries build; users run this with ./dotnet.sh run -c Release. -->
    <IsPackable>false</IsPackable>
    <IsShipping>false</IsShipping>
    <SkipTests>true</SkipTests>
    <!-- Ad-hoc benchmark code; the production analyzer rules don't apply. -->
    <EnableAnalyzers>false</EnableAnalyzers>
    <EnableNETAnalyzers>false</EnableNETAnalyzers>
    <RunAnalyzers>false</RunAnalyzers>
    <NoWarn>$(NoWarn);CA2007;CA2025;CS3016;CS1591;SYSLIB5007</NoWarn>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <CLSCompliant>false</CLSCompliant>
    <GenerateAssemblyCLSCompliantAttribute>false</GenerateAssemblyCLSCompliantAttribute>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="Program.cs" />
    <!-- BenchmarkDotNet attributes are defined in netstandard2.0; the libraries
         build chain doesn't auto-reference the netstandard facade. Pull it in
         from the local targeting pack. -->
    <Reference Include="netstandard">
      <HintPath>$(MicrosoftNetCoreAppRefPackRefDir)netstandard.dll</HintPath>
    </Reference>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="BenchmarkDotNet" Version="0.15.0" />
  </ItemGroup>
</Project>
