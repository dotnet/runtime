<?xml version="1.0" encoding="utf-8" ?>
<asn:Sequence
  xmlns:asn="http://schemas.dot.net/asnxml/201808/"
  name="PfxAsn"
  namespace="System.Security.Cryptography.Asn1.Pkcs12"
  emitType="both">

  <!--
    https://tools.ietf.org/html/rfc7292#section-4

    PFX ::= SEQUENCE {
        version    INTEGER {v3(3)}(v3,...),
        authSafe   ContentInfo,
        macData    MacData OPTIONAL
    }
  -->
  <asn:Integer name="Version" backingType="int" />
  <asn:AsnType
    name="AuthSafe"
    typeName="System.Security.Cryptography.Asn1.Pkcs7.ContentInfoAsn"
    valueTypeName="System.Security.Cryptography.Asn1.Pkcs7.ValueContentInfoAsn" />
  <asn:AsnType
    name="MacData"
    typeName="System.Security.Cryptography.Asn1.Pkcs12.MacData"
    valueTypeName="System.Security.Cryptography.Asn1.Pkcs12.ValueMacData"
    optional="true" />
</asn:Sequence>
