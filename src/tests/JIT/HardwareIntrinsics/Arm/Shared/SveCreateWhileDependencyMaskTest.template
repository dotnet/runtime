using System;
using System.Numerics;
using System.Reflection;
using System.Runtime.CompilerServices;
using System.Runtime.InteropServices;
using System.Runtime.Intrinsics;
using System.Runtime.Intrinsics.Arm;
using Xunit;

// Test template for CreateWhileWriteAfterRead* and CreateWhileReadAfterWrite* in SVE2

namespace {Namespace}
{
    public static partial class Program
    {
        [Fact]
        public static void {TestName}()
        {
            var test = new CreateWhileDependencyMaskTest__{TestName}();

            if (test.IsSupported)
            {
                // Validates that same-address produces an all-true mask
                test.RunSameAddressScenario();

                // Validates calling via reflection works
                test.RunReflectionScenario();

                // Validates when op2 is one element after op1
                test.RunOffsetByOneScenario();

                // Validate when op2 is one element before op1:
                // WHILERW returns a single-true mask; WHILEWR returns an all-true mask.
                test.RunReverseOffsetByOneScenario();
            }
            else
            {
                // Validates we throw on unsupported hardware
                test.RunUnsupportedScenario();
            }

            if (!test.Succeeded)
            {
                throw new Exception("One or more scenarios did not complete as expected.");
            }
        }
    }

    public sealed unsafe class CreateWhileDependencyMaskTest__{TestName}
    {
        public bool IsSupported => {Isa}.IsSupported;

        public bool Succeeded { get; set; } = true;

        public void RunSameAddressScenario()
        {
            TestLibrary.TestFramework.BeginScenario(nameof(RunSameAddressScenario));

            {Op1BaseType}* ptr = stackalloc {Op1BaseType}[{RetVectorType}<{RetBaseType}>.Count];
            {RetVectorType}<{RetBaseType}> mask = {Isa}.{Method}(ptr, ptr);
            ValidateElementsEqual(mask, 0, true);
        }

        public void RunReflectionScenario()
        {
            TestLibrary.TestFramework.BeginScenario(nameof(RunReflectionScenario));

            {Op1BaseType}* ptr = stackalloc {Op1BaseType}[{RetVectorType}<{RetBaseType}>.Count];
            var result = typeof({Isa}).GetMethod(nameof({Isa}.{Method}), new Type[] { typeof({Op1BaseType}*), typeof({Op1BaseType}*) })
                                     .Invoke(null, new object[] {
                                        Pointer.Box(ptr, typeof({Op1BaseType}*)),
                                        Pointer.Box(ptr, typeof({Op1BaseType}*))
                                     });

            {RetVectorType}<{RetBaseType}> mask = ({RetVectorType}<{RetBaseType}>)result;
            ValidateElementsEqual(mask, 0, true);
        }

        public void RunOffsetByOneScenario()
        {
            TestLibrary.TestFramework.BeginScenario(nameof(RunOffsetByOneScenario));

            {Op1BaseType}* ptr = stackalloc {Op1BaseType}[{RetVectorType}<{RetBaseType}>.Count + 1];
            {RetVectorType}<{RetBaseType}> mask = {Isa}.{Method}(ptr, ptr + 1);

            if (mask.GetElement(0) == 0)
            {
                TestLibrary.TestFramework.LogInformation(
                    $"{nameof({Isa})}.{nameof({Isa}.{Method})}(ptr, ptr+1): Expected element 0 to be true.");
                Succeeded = false;
                return;
            }

            ValidateElementsEqual(mask, 1, false);
        }

        public void RunReverseOffsetByOneScenario()
        {
            TestLibrary.TestFramework.BeginScenario(nameof(RunReverseOffsetByOneScenario));

            {Op1BaseType}* ptr = stackalloc {Op1BaseType}[{RetVectorType}<{RetBaseType}>.Count + 1];
            {RetVectorType}<{RetBaseType}> mask = {Isa}.{Method}(ptr + 1, ptr);

            /*
            for op1 = op2 + 1, WHILEWR creates an all true mask.  WHILERW creates a mask of true, then all false.
            WHILEWR:
                constant integer diff = (operand2 - operand1) DIV (esize DIV 8);
                for e = 0 to elements-1
                    if diff <= 0 || e < diff then
                        Elem[result, e, psize] = ZeroExtend('1', psize);
            WHILERW:
                constant integer diff = Abs(operand2 - operand1) DIV (esize DIV 8);
                for e = 0 to elements-1
                    if diff == 0 || e < diff then
                        Elem[result, e, psize] = ZeroExtend('1', psize);
            */
            if ({IsWriteAfterRead})
            {
                ValidateElementsEqual(mask, 0, true);
            }
            else
            {
                if (mask.GetElement(0) == 0)
                {
                    TestLibrary.TestFramework.LogInformation(
                        $"{nameof({Isa})}.{nameof({Isa}.{Method})}(ptr+1, ptr): Expected element 0 to be true.");
                    Succeeded = false;
                    return;
                }

                ValidateElementsEqual(mask, 1, false);
            }
        }

        private void ValidateElementsEqual({RetVectorType}<{RetBaseType}> mask, int startIndex, bool expectedVal, [CallerMemberName] string method = "")
        {
            int count = {RetVectorType}<{RetBaseType}>.Count;

            for (int i = startIndex; i < count; i++)
            {
                bool actualVal = mask.GetElement(i) != 0;

                if (actualVal != expectedVal)
                {
                    TestLibrary.TestFramework.LogInformation(
                        $"{nameof({Isa})}.{nameof({Isa}.{Method})}: {method} failed at element {i}: expected {(expectedVal ? "true" : "false")}.");
                    Succeeded = false;
                    return;
                }
            }
        }

        public void RunUnsupportedScenario()
        {
            TestLibrary.TestFramework.BeginScenario(nameof(RunUnsupportedScenario));

            bool succeeded = false;

            try
            {
                RunSameAddressScenario();
            }
            catch (PlatformNotSupportedException)
            {
                succeeded = true;
            }

            if (!succeeded)
            {
                Succeeded = false;
            }
        }
    }
}
