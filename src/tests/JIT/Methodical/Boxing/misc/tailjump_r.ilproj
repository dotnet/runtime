<Project Sdk="Microsoft.NET.Sdk.IL">
  <PropertyGroup>
    <MonoAotIncompatible>true</MonoAotIncompatible>  <!-- https://github.com/dotnet/runtime/issues/90427  -->
    <DisableProjectBuild Condition="'$(RuntimeFlavor)' == 'mono' and '$(RuntimeVariant)' == 'minifullaot'">true</DisableProjectBuild>
  </PropertyGroup>
  <PropertyGroup>
    <DebugType>PdbOnly</DebugType>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="tailjump_r.il" />
    <Compile Include="tailjump.il" />
  </ItemGroup>
</Project>
