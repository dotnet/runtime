<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <CrossGenTest>false</CrossGenTest>
    <RequiresProcessIsolation>true</RequiresProcessIsolation>
    <DebugType>None</DebugType>
    <Optimize>True</Optimize>
    <InterpreterIncompatible>true</InterpreterIncompatible>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="$(MSBuildProjectName).cs" />

    <CLRTestEnvironmentVariable Include="DOTNET_TieredCompilation" Value="1" />
    <CLRTestEnvironmentVariable Include="DOTNET_TieredPGO" Value="1" />
    <CLRTestEnvironmentVariable Include="DOTNET_JitObjectStackAllocationConditionalEscape" Value="1" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="$(TestLibraryProjectPath)" />
  </ItemGroup>
</Project>
