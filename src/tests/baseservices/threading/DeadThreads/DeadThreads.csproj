<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- Needed for CLRTestEnvironmentVariable, GCStressIncompatible -->
    <RequiresProcessIsolation>true</RequiresProcessIsolation>
    <!-- This test creates threads at a very high rate, which can lead to OOM under GC stress -->
    <GCStressIncompatible>true</GCStressIncompatible>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="$(MSBuildProjectName).cs" />

    <CLRTestEnvironmentVariable Include="DOTNET_Thread_DeadThreadCountThresholdForGCTrigger" Value="8" />
    <CLRTestEnvironmentVariable Include="DOTNET_Thread_DeadThreadGCTriggerPeriodMilliseconds" Value="3e8" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="$(TestLibraryProjectPath)" />
  </ItemGroup>
</Project>
