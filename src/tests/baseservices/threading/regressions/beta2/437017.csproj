<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- WASI: see https://github.com/dotnet/runtime/issues/120708 -->
    <CLRTestTargetUnsupported Condition="'$(TargetsWasi)' == 'true'">true</CLRTestTargetUnsupported>
    <!-- Needed for UnloadabilityIncompatible -->
    <RequiresProcessIsolation>true</RequiresProcessIsolation>
    <!-- This test leaves random number of WaitOrTimerCallbacks registered at the exit, which prevents unloading -->
    <UnloadabilityIncompatible>true</UnloadabilityIncompatible>
    <CLRTestPriority>1</CLRTestPriority>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="437017.cs" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="$(TestLibraryProjectPath)" />
  </ItemGroup>
</Project>
