<Project Sdk="Microsoft.NET.Sdk.IL">
  <PropertyGroup>
    <!-- WASI: see https://github.com/dotnet/runtime/issues/120708 -->
    <CLRTestTargetUnsupported Condition="'$(TargetsWasi)' == 'true'">true</CLRTestTargetUnsupported>
    <MonoAotIncompatible>true</MonoAotIncompatible>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="nopiatestil.il" />
    <ProjectReference Include="basetestclassesil.ilproj" />
    <ProjectReference Include="testclassesil.ilproj" />
    <ProjectReference Include="$(TestLibraryProjectPath)" />
  </ItemGroup>
</Project>
