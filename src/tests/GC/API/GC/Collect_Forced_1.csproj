<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- WASI: see https://github.com/dotnet/runtime/issues/120708 -->
    <CLRTestTargetUnsupported Condition="'$(TargetsWasi)' == 'true'">true</CLRTestTargetUnsupported>
    <!-- Needed for GCStressIncompatible -->
    <RequiresProcessIsolation>true</RequiresProcessIsolation>

    <!-- Test needs explicit Main as it uses command-line parameters -->
    <ReferenceXUnitWrapperGenerator>false</ReferenceXUnitWrapperGenerator>
    <CLRTestExecutionArguments>0</CLRTestExecutionArguments>

    <CLRTestPriority>1</CLRTestPriority>
  </PropertyGroup>
  <PropertyGroup>
    <DebugType>PdbOnly</DebugType>
    <GCStressIncompatible>true</GCStressIncompatible>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="Collect_Forced.cs" />
  </ItemGroup>
</Project>
