<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- WASI: see https://github.com/dotnet/runtime/issues/120708 -->
    <CLRTestTargetUnsupported Condition="'$(TargetsWasi)' == 'true'">true</CLRTestTargetUnsupported>
    <CLRTestPriority>0</CLRTestPriority>
    <RequiresProcessIsolation>true</RequiresProcessIsolation>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="GetConfigurationVariables.cs" />
  </ItemGroup>
  <ItemGroup>
    <CLRTestEnvironmentVariable Include="DOTNET_GCHeapAffinitizeRanges" Value="1" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="$(TestLibraryProjectPath)" />
  </ItemGroup>
</Project>
