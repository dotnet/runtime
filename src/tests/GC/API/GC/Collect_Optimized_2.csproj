<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- Needed for ReferenceXUnitWrapperGenerator=false (custom Main entry point) -->
    <RequiresProcessIsolation>true</RequiresProcessIsolation>

    <!-- Test needs explicit Main as it uses command-line parameters -->
    <ReferenceXUnitWrapperGenerator>false</ReferenceXUnitWrapperGenerator>
    <CLRTestExecutionArguments>1</CLRTestExecutionArguments>
  </PropertyGroup>
  <PropertyGroup>
    <DebugType>PdbOnly</DebugType>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="Collect_Optimized.cs" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="$(TestLibraryProjectPath)" />
  </ItemGroup>
</Project>
