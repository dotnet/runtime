<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!-- WASI: see https://github.com/dotnet/runtime/issues/120708 -->
    <CLRTestTargetUnsupported Condition="'$(TargetsWasi)' == 'true'">true</CLRTestTargetUnsupported>
    <!-- Needed for GCStressIncompatible, HeapVerifyIncompatible -->
    <RequiresProcessIsolation>true</RequiresProcessIsolation>
    <HeapVerifyIncompatible Condition="'$(TargetArchitecture)' == 'arm'">true</HeapVerifyIncompatible>
  </PropertyGroup>
  <PropertyGroup>
    <DebugType>PdbOnly</DebugType>
    <GCStressIncompatible>true</GCStressIncompatible>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="GetTotalAllocatedBytes.cs" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="$(TestLibraryProjectPath)" />
  </ItemGroup>
</Project>
