<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <CLRTestPriority>0</CLRTestPriority>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Test interacts with GC collections, also needed for CLRTestTargetUnsupported below -->
    <RequiresProcessIsolation>true</RequiresProcessIsolation>
    <ServerGarbageCollection>true</ServerGarbageCollection>
    <!-- Native dependencies are not available in these mobile test legs. -->
    <CLRTestTargetUnsupported Condition="'$(TargetsAppleMobile)' == 'true'">true</CLRTestTargetUnsupported>
    <CLRTestTargetUnsupported Condition="'$(TargetsAndroid)' == 'true'">true</CLRTestTargetUnsupported>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="../Common.cs" />
    <Compile Include="Program.cs" />
  </ItemGroup>

  <ItemGroup>
    <CMakeProjectReference Include="../MockReferenceTrackerRuntime/CMakeLists.txt" />
  </ItemGroup>
</Project>
