<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <IsRoslynComponent>true</IsRoslynComponent>
    <AnalyzerLanguage>cs</AnalyzerLanguage>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <IsShipping>false</IsShipping>
    <IsPackable>false</IsPackable>
  </PropertyGroup>
  <!-- Remove the ExperimentalAttribute added by Directory.Build.props since
       netstandard2.0 does not have System.Diagnostics.CodeAnalysis.ExperimentalAttribute -->
  <ItemGroup>
    <AssemblyAttribute Remove="System.Diagnostics.CodeAnalysis.ExperimentalAttribute" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="$(MicrosoftCodeAnalysisVersion_LatestVS)" PrivateAssets="all" />
  </ItemGroup>
</Project>
