<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>$(NetCoreAppToolCurrent)</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsShipping>false</IsShipping>
    <IsPackable>false</IsPackable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <AssemblyName>CdacUsageGraph</AssemblyName>
    <!-- The tool lives under src/native/managed/cdac, whose Directory.Build.props marks assemblies
         with [Experimental("NETCDAC0001")]; the tool has no external consumers, so suppress it. -->
    <NoWarn>$(NoWarn);NETCDAC0001</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Build" Version="$(MicrosoftBuildVersion)" ExcludeAssets="runtime" />
    <PackageReference Include="Microsoft.Build.Framework" Version="$(MicrosoftBuildFrameworkVersion)" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="$(MicrosoftCodeAnalysisVersion_LatestVS)" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="$(MicrosoftCodeAnalysisVersion_LatestVS)" />
    <PackageReference Include="Microsoft.CodeAnalysis.Workspaces.MSBuild" Version="$(MicrosoftCodeAnalysisVersion_LatestVS)" />
    <PackageReference Include="System.CommandLine" Version="$(SystemCommandLineVersion)" />
  </ItemGroup>

  <ItemGroup>
    <!-- MSBuildWorkspace intentionally evaluates Contracts in Debug for deterministic analysis.
         Ensure that exact analyzer output exists in every tool build configuration. The generator
         is loaded by Contracts' analyzer ProjectReference, not linked into this tool. -->
    <ProjectReference Include="..\..\..\..\gen\Microsoft.Diagnostics.DataContractReader.DataGenerator.csproj"
                      ReferenceOutputAssembly="false"
                      AdditionalProperties="Configuration=Debug"
                      GlobalPropertiesToRemove="RuntimeIdentifier" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="CdacUsageGraph.Tests" />
  </ItemGroup>

</Project>
